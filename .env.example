# ── PCI WhatsApp Bot (V1.6) — environment ───────────────────────
# Copy this file to `.env` and fill in the values. Never commit `.env`.

# Server
PORT=8090
# Shared secret WAHA must send so only WAHA can hit our webhook.
WEBHOOK_TOKEN=change-me-to-a-long-random-string

# ── WAHA (standalone instance dedicated to PCI) ─────────────────
WAHA_BASE_URL=http://localhost:3001
WAHA_SESSION=default
WAHA_API_KEY=

# ── Gemini ──────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Security ────────────────────────────────────────────────────
# Comma-separated list of phone numbers (with country code, no +) that can use the bot.
ADMIN_SALES_NUMBERS=923001234567
STANDARD_SALES_NUMBERS=923111234567
