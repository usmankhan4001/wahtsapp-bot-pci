# ── PCI WhatsApp Bot — environment ──────────────────────────────
# Copy this file to `.env` and fill in the values. Never commit `.env`.

# Server
PORT=8090
# Shared secret WAHA must send so only WAHA can hit our webhook (set the same value in WAHA's webhook config).
WEBHOOK_TOKEN=change-me-to-a-long-random-string

# ── WAHA (standalone instance dedicated to PCI, e.g. port 3001) ──
WAHA_BASE_URL=http://localhost:3001
WAHA_SESSION=default
WAHA_API_KEY=            # X-Api-Key configured on the WAHA container (optional but recommended)

# ── Gemini ──────────────────────────────────────────────────────
GEMINI_API_KEY=          # (Phase 3) ready, paste when wiring the AI layer
GEMINI_MODEL=gemini-2.0-flash

# ── Bitrix24 calculator backend (existing, live) ────────────────
BITRIX_API_BASE=https://bitrix24calculatorv2.premierchoiceint.online

# ── Notifications / routing (fill when provided) ────────────────
# Sales manager — notified when a lead is engaged and when a proposal is sent.
SALES_MANAGER_WHATSAPP=
# Human team handoff targets (B2B / B2C / Customer Care).
TEAM_B2B_WHATSAPP=
TEAM_B2C_WHATSAPP=
TEAM_CARE_WHATSAPP=
